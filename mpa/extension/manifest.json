{
  "manifest_version": 3,
  "name": "MPA for Linux",
  "version": "24.0.1",
  "description": "Linuxユーザーでも様々なオンライン行政サービスを利用するためのアプリケーションです。非公式ですので自己責任でご利用ください。",
  "key": "",
  "permissions": [
    "nativeMessaging"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.go.jp/*"
      ],
      "run_at": "document_start",
      "js": ["windows.js"],
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.go.jp/*"
      ],
      "run_at": "document_end",
      "js": ["content.js"]
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "test@example.com",
      "strict_min_version": "50.0"
    }
  },
  "action": {
    "default_title": "MPA for Linux",
    "default_popup": "popup.html"
  }
}
